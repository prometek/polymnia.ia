# Keep the build context lean (Dockerfile.render-worker builds from repo root,
# so it needs both backend/ and render-motor/ but nothing else below).

.git
.github
.claude/worktrees

# Python (backend/)
**/__pycache__
**/.venv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache

# Node / Remotion (render-motor/)
**/node_modules

# Regenerated artefacts, never baked into the image
**/out
render-motor/public/audio
render-motor/render-input*.json

# Secrets — never in the build context
backend/.env
**/*.env
**/*.env.*
*.pem
*.key

**/.DS_Store
